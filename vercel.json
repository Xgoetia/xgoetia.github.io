{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/pkg/(.*).wasm",
      "headers": {
        "Content-Type": "application/wasm"
      },
      "dest": "/pkg/$1.wasm"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
